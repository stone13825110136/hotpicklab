---
import Layout from '../../layouts/Layout.astro';
import tools from '../../data/tools.json';
---

<Layout
  title="Free Shopping & Creator Tools — Deal Math, Timers & More"
  description="Practical free calculators for shoppers and creators — no sign-up, works in your browser."
  keywords={['free online tools', 'deal calculator', 'video size calculator']}
>
  <section class="hero">
    <h1>Free tools</h1>
    <p class="muted">
      Small, focused utilities you can bookmark or add to your home screen. Open anytime — no article required.
    </p>
  </section>
  <div class="grid">
    {
      tools.map((tool) => (
        <article class="card">
          <h2>
            <a href={`/tools/${tool.slug}`}>{tool.title}</a>
          </h2>
          <p>{tool.description}</p>
          <a class="btn" href={`/tools/${tool.slug}`}>Open tool →</a>
        </article>
      ))
    }
  </div>
</Layout>
