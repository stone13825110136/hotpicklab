---
import Layout from '../../layouts/Layout.astro';
import tools from '../../data/tools.json';
---

<Layout
  title="Free Micro Tools"
  description="Small utilities matched to trending topics — video sizes, gaming timers, sale calculators."
  keywords={['online tools', 'video size calculator', 'gaming timer']}
>
  <section class="hero">
    <h1>Trend-matched tools</h1>
    <p class="muted">Tools exist to rank on long-tail searches and funnel readers into trend guides.</p>
  </section>
  <div class="grid">
    {
      tools.map((tool) => (
        <article class="card">
          <h2>
            <a href={`/tools/${tool.slug}`}>{tool.title}</a>
          </h2>
          <p>{tool.description}</p>
          <a class="btn" href={`/tools/${tool.slug}`}>Open →</a>
        </article>
      ))
    }
  </div>
</Layout>
