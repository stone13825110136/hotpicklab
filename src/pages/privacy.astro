---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../lib/site';
---

<Layout title="Privacy Policy — How HotPick Lab Handles Visitor Data" description="Privacy policy for HotPick Lab.">
  <article class="prose">
    <h1>Privacy Policy</h1>
    <p>Last updated: July 2, 2026</p>
    <p>
      {SITE.name} ("we") operates {SITE.url}. This page explains how we handle information when you visit our site.
    </p>
    <h2>Analytics & advertising</h2>
    <p>
      We may use Google Analytics and Google AdSense. These services use cookies to measure traffic and show ads.
      You can opt out via Google's ad settings and browser cookie controls.
    </p>
    <h2>Affiliate links</h2>
    <p>
      Outbound affiliate links may set third-party cookies when you click them. See our
      <a href="/disclosure">Affiliate Disclosure</a>.
    </p>
    <h2>Contact</h2>
    <p>
      Email: <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>
    </p>
  </article>
</Layout>
