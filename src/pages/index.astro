---
import Layout from '../layouts/Layout.astro';
import TrendCard from '../components/TrendCard.astro';
import trends from '../data/trends.json';
import searchHubLinks from '../data/search-hub-links.json';
import { CATEGORIES, SITE } from '../lib/site';

const grouped = (['ai-tools', 'amazon-trending', 'gaming', 'seasonal'] as const)
  .map((id) => ({
    label: CATEGORIES[id] ?? id,
    items: trends.filter((t) => t.category === id),
  }))
  .filter((g) => g.items.length > 0);
---

<Layout
  title="Viral Amazon & AI Buying Briefs — Worth It Guides"
  description={SITE.description}
  keywords={['worth it reviews', 'buying briefs', 'trending products 2026', 'amazon viral products']}
>
  <section class="hero">
    <h1>Buying briefs</h1>
    <p class="muted hero-lead">
      Structured verdicts on viral Amazon products, AI creator tools, gaming gear, and seasonal deals.
    </p>
  </section>

  <section class="search-hub">
    <h2 class="section-title">Popular worth-it searches</h2>
    <p class="muted">Full brief on each link — verdict, skip list, and picks.</p>
    <ul class="hub-links">
      {searchHubLinks.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
  </section>

  {
    grouped.map((group) => (
      <section class="category-block">
        <h2 class="section-title">{group.label}</h2>
        <div class="grid">
          {group.items.map((trend) => <TrendCard trend={trend} />)}
        </div>
      </section>
    ))
  }
</Layout>

<style>
  .hero-lead { max-width: 40rem; }

  .search-hub {
    margin-top: 2rem;
    padding: 1.2rem 1.3rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .hub-links {
    list-style: none;
    margin: 0.75rem 0 0;
    padding: 0;
    display: grid;
    gap: 0.45rem;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  }

  .hub-links a { font-weight: 600; font-size: 0.94rem; }

  .category-block { margin-top: 2.5rem; }
</style>
