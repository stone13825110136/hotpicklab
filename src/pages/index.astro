---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../lib/site';

const buyHref = `mailto:${SITE.contactEmail}?subject=${encodeURIComponent(
  `${SITE.productName} — $${SITE.priceUsd}`,
)}&body=${encodeURIComponent(
  [
    'I want to buy the Pain Point Research Report ($49).',
    '',
    'After you confirm payment instructions, I will fill intake:',
    '1) Target user',
    '2) Job / problem in their words',
    '3) Competitors (or none)',
    '4) Keywords',
    '5) What I will NOT build',
    '6) What “good” looks like in 30 days',
    '7) Next-week test budget',
    '8) Email for the report',
  ].join('\n'),
)}`;
---

<Layout
  title={SITE.name}
  description={SITE.description}
  keywords={[
    'pain point research',
    'indie hacker validation',
    'Reddit market research',
    'Hacker News research',
    'product idea validation',
  ]}
>
  <section class="hero">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="brand-mark" translate="no">{SITE.name}</p>
        <h1>See who’s in pain before you write more code</h1>
        <p class="lede">
          For builders with coding tools who fear shipping blind. Reddit and HN evidence → filter pay
          signals → email a one-week validation plan.
        </p>
        <div class="cta-row">
          <a class="cta" href={buyHref}>Get the report — ${SITE.priceUsd}</a>
          <p class="cta-note">7-day money-back. Card checkout next; email purchase works now.</p>
        </div>
      </div>

      <aside class="thread-sheet" aria-label="Example public complaints">
        <div class="thread-line">
          <span class="src">r/SaaS</span>
          <span>built for 6 months, zero paying users</span>
        </div>
        <div class="thread-line">
          <span class="src">HN</span>
          <span>tired of shipping features nobody asked for</span>
        </div>
        <div class="thread-line">
          <span class="src">r/entrepreneur</span>
          <span>how do I know people will pay before I code?</span>
        </div>
        <div class="thread-line dim">
          <span class="src">filter</span>
          <span>repeat · intensity · pay smell · counter-evidence</span>
        </div>
      </aside>
    </div>
  </section>

  <section class="section" id="offer">
    <div class="shell narrow">
      <h2>What you get</h2>
      <p class="section-lede">
        A research report by email — not a mentoring call, not a “you’ll get rich” forecast.
      </p>
      <ul class="plain-list">
        <li>Pain / opportunity notes with clickable public source URLs</li>
        <li>Fixed rubric labels: repeat, intensity, pay smell, worth validating</li>
        <li>Counter-evidence — why it might not sell</li>
        <li>A cheap next test for this week (talk, landing, or pre-sale — not a full build)</li>
      </ul>
    </div>
  </section>

  <section class="section section-alt" id="sources">
    <div class="shell narrow">
      <h2>Where evidence comes from</h2>
      <p class="section-lede">
        Primary sources are public Reddit threads and Hacker News. If you name competitors, we add
        review-site signal (e.g. G2). Every claim should map to a URL you can open.
      </p>
    </div>
  </section>

  <section class="section" id="promise">
    <div class="shell narrow">
      <h2>What we don’t promise</h2>
      <p class="section-lede">
        We don’t know if your direction is “right.” Markets decide with money. We show who’s
        complaining in public, whether it smells like pay, and how to test cheaply this week.
      </p>
    </div>
  </section>

  <section class="section section-alt" id="price">
    <div class="shell narrow">
      <h2>${SITE.priceUsd} · Pain Point Research Report</h2>
      <p class="section-lede">
        After purchase you’ll get a short intake (target user, job-to-be-done, competitors,
        keywords, won’t-build, success criteria). Missing the basics means we pause and ask —
        we don’t invent your customer for you.
      </p>
      <a class="cta cta-inline" href={buyHref}>Email to buy — ${SITE.priceUsd}</a>
      <p class="fine">Refund within 7 days if the report doesn’t meet the sourced-research bar.</p>
    </div>
  </section>
</Layout>

<style>
  .hero {
    background: var(--paper);
    border-bottom: 1px solid var(--line);
    padding: 3.5rem 0 4rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: 2.5rem;
    align-items: center;
  }

  .brand-mark {
    margin: 0 0 0.85rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 4.5vw, 2.75rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--ink);
    white-space: nowrap;
  }

  .hero h1 {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.35rem, 2.6vw, 1.75rem);
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--ink-soft);
    max-width: 22ch;
  }

  .lede {
    margin: 0 0 1.75rem;
    color: var(--ink-soft);
    font-size: 1.05rem;
    font-weight: 400;
    max-width: 34rem;
  }

  .cta-row {
    display: grid;
    gap: 0.7rem;
    justify-items: start;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.2rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.01em;
    color: #fff;
    background: var(--ink);
    text-decoration: none;
    border: 1px solid var(--ink);
  }

  .cta:hover {
    background: var(--signal);
    border-color: var(--signal);
    color: #fff;
  }

  .cta-inline {
    margin-top: 1rem;
  }

  .cta-note,
  .fine {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--muted);
    max-width: 28rem;
  }

  .thread-sheet {
    background: var(--panel-dark);
    color: #e8ecf2;
    padding: 1.35rem 1.4rem;
    border-left: 3px solid var(--signal-bright);
  }

  .thread-line {
    display: grid;
    grid-template-columns: 7.5rem 1fr;
    gap: 0.75rem;
    padding: 0.7rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.45;
  }

  .thread-line:first-child {
    padding-top: 0;
  }

  .thread-line:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .thread-line.dim {
    color: #a8b2c2;
  }

  .src {
    color: var(--signal-bright);
    text-transform: uppercase;
    letter-spacing: 0.03em;
    font-weight: 500;
  }

  .section {
    padding: 3.5rem 0;
    background: var(--panel);
  }

  .section-alt {
    background: var(--paper);
    border-block: 1px solid var(--line);
  }

  .narrow {
    max-width: 40rem;
  }

  .section h2 {
    margin: 0 0 0.65rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.35rem, 2.4vw, 1.7rem);
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .section-lede {
    margin: 0;
    color: var(--ink-soft);
    font-size: 1.05rem;
  }

  .plain-list {
    margin: 1.25rem 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.85rem;
  }

  .plain-list li {
    padding-left: 0.9rem;
    border-left: 2px solid var(--signal);
    color: var(--ink-soft);
  }

  @media (max-width: 860px) {
    .hero {
      padding: 2.25rem 0 2.5rem;
    }

    .hero-grid {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }

    .brand-mark {
      white-space: normal;
    }

    .hero h1 {
      max-width: none;
    }

    .thread-line {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
