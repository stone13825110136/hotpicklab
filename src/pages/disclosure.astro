---
import Layout from '../layouts/Layout.astro';
import { AFFILIATE_DISCLOSURE, SITE } from '../lib/site';
---

<Layout title="Affiliate Disclosure — How HotPick Lab Earns Commissions" description="Affiliate disclosure for HotPick Lab.">
  <article class="prose">
    <h1>Affiliate Disclosure</h1>
    <p>{AFFILIATE_DISCLOSURE}</p>
    <p>
      {SITE.name} participates in affiliate programs including Amazon Associates and software partner programs.
      We only recommend products relevant to trending topics we cover.
    </p>
  </article>
</Layout>
