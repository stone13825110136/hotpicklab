---
import Layout from '../../layouts/Layout.astro';
import TrendCard from '../../components/TrendCard.astro';
import trends from '../../data/trends.json';
import searchHubLinks from '../../data/search-hub-links.json';
import { CATEGORIES } from '../../lib/site';

const byCategory = Object.entries(
  trends.reduce<Record<string, typeof trends>>((acc, trend) => {
    (acc[trend.category] ??= []).push(trend);
    return acc;
  }, {}),
);
---

<Layout
  title="Buying Briefs"
  description="Independent buying briefs on trending US products — structured verdicts, skip lists, and compared picks."
  keywords={['buying briefs', 'worth it reviews', 'trending products', 'viral amazon finds', 'ai tools 2026']}
>
  <section class="hero">
    <h1>Buying briefs</h1>
    <p class="muted brief-lead">
      Structured verdicts on viral Amazon products, AI creator tools, gaming gear, and seasonal deals.
    </p>
  </section>

  <section class="search-hub" aria-labelledby="search-hub-heading">
    <h2 id="search-hub-heading">Popular worth-it searches</h2>
    <p class="muted hub-intro">US shoppers search these before they buy — each link opens a full brief with verdict, skip list, and picks.</p>
    <ul class="hub-links">
      {searchHubLinks.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
    </ul>
  </section>

  {
    byCategory.map(([category, items]) => (
      <section class="category-block">
        <h2 class="section-title">{CATEGORIES[category] ?? category}</h2>
        <div class="grid">
          {items.map((trend) => (
            <TrendCard trend={trend} />
          ))}
        </div>
      </section>
    ))
  }
</Layout>

<style>
  .brief-lead {
    max-width: 40rem;
  }

  .search-hub {
    margin: 1.5rem 0 2.5rem;
    padding: 1.25rem 1.35rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }

  .hub-intro {
    margin: 0.25rem 0 1rem;
    font-size: 0.92rem;
  }

  .hub-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.45rem 1.25rem;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  }

  .hub-links a {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .category-block {
    margin-top: 2rem;
  }
</style>
