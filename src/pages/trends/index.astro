---
import Layout from '../../layouts/Layout.astro';
import TrendCard from '../../components/TrendCard.astro';
import trends from '../../data/trends.json';
---

<Layout
  title="Buying Briefs"
  description="Independent buying briefs on trending US products — structured verdicts, skip lists, and compared picks."
  keywords={['buying briefs', 'worth it reviews', 'trending products', 'viral amazon finds', 'ai tools 2026']}
>
  <section class="hero">
    <h1>Buying briefs</h1>
    <p class="muted brief-lead">
      Structured verdicts on viral Amazon products, AI creator tools, gaming gear, and seasonal deals.
    </p>
  </section>
  <div class="grid">
    {trends.map((trend) => <TrendCard trend={trend} />)}
  </div>
</Layout>

<style>
  .brief-lead {
    max-width: 40rem;
  }
</style>
