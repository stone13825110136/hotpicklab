---
import Layout from '../../layouts/Layout.astro';
import TrendCard from '../../components/TrendCard.astro';
import trends from '../../data/trends.json';
---

<Layout
  title="Hot Trends"
  description="Trending products and tools in the US market — curated picks with honest pros, cons, and prices."
  keywords={['trending products', 'viral amazon finds', 'ai tools 2026', 'worth it reviews']}
>
  <section class="hero">
    <h1>Hot trends</h1>
    <p class="muted">
      What's spiking right now in the US — narrowed to picks worth your attention, with clear pros and cons.
    </p>
  </section>
  <div class="grid">
    {trends.map((trend) => <TrendCard trend={trend} />)}
  </div>
</Layout>
