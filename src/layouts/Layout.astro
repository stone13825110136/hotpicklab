---
import { SITE } from '../lib/site';

interface Props {
  title: string;
  description: string;
  keywords?: string[];
  type?: 'website' | 'article';
}

const { title, description, keywords = [], type = 'website' } = Astro.props;
const fullTitle = title === SITE.name ? title : `${title} | ${SITE.name}`;
const canonical = new URL(Astro.url.pathname, SITE.url).href;
---

<!doctype html>
<html lang="en" translate="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google" content="notranslate" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="robots" content="index, follow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="notranslate">
    <a class="skip" href="#main">Skip to content</a>
    <header class="site-header">
      <div class="shell header-inner">
        <a class="logo" href="/" translate="no">{SITE.name}</a>
        <nav aria-label="Primary">
          <a href="/#offer">Offer</a>
          <a href="/#price">Price</a>
          <a href={`mailto:${SITE.contactEmail}`}>Contact</a>
        </nav>
      </div>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell footer-inner">
        <p class="footer-brand" translate="no">{SITE.name}</p>
        <p class="footer-note">{SITE.tagline}</p>
        <p class="footer-links">
          <a href="/privacy">Privacy</a>
          <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>
        </p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --ink: #12151a;
    --ink-soft: #2a3140;
    --muted: #4a5568;
    --paper: #f6f7f9;
    --panel: #ffffff;
    --panel-dark: #171b22;
    --signal: #0d6e62;
    --signal-bright: #1aa38f;
    --line: #d8dee8;
    --max: 68rem;
    --font-display: 'Space Grotesk', sans-serif;
    --font-body: 'IBM Plex Sans', sans-serif;
    --font-mono: 'IBM Plex Mono', ui-monospace, monospace;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 1.0625rem;
    font-weight: 400;
    line-height: 1.6;
    background: var(--paper);
  }

  a {
    color: var(--signal);
  }

  a:hover {
    color: var(--ink);
  }

  .skip {
    position: absolute;
    left: -9999px;
    top: 0;
    background: var(--ink);
    color: #fff;
    padding: 0.5rem 0.75rem;
    z-index: 100;
  }

  .skip:focus {
    left: 0.75rem;
    top: 0.75rem;
  }

  .shell {
    width: min(100% - 2rem, var(--max));
    margin-inline: auto;
  }

  .site-header {
    border-bottom: 1px solid var(--line);
    background: var(--panel);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 0;
    gap: 1rem;
  }

  .logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    letter-spacing: -0.03em;
    color: var(--ink);
    text-decoration: none;
    white-space: nowrap;
  }

  nav {
    display: flex;
    gap: 1.25rem;
  }

  nav a {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    color: var(--muted);
  }

  nav a:hover {
    color: var(--ink);
  }

  .site-footer {
    margin-top: 0;
    border-top: 1px solid var(--line);
    padding: 2rem 0 2.5rem;
    background: var(--panel);
    color: var(--muted);
  }

  .footer-inner {
    display: grid;
    gap: 0.25rem;
  }

  .footer-brand {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--ink);
  }

  .footer-note,
  .footer-links {
    margin: 0;
    font-size: 0.95rem;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 0.65rem;
  }

  .footer-links a {
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
  }

  @media (max-width: 640px) {
    nav {
      gap: 0.85rem;
    }

    nav a {
      font-size: 0.85rem;
    }
  }
</style>
