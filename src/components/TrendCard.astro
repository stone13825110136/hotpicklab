---
import { CATEGORIES } from '../lib/site';

interface Trend {
  slug: string;
  title: string;
  category: string;
  trendScore: number;
  summary: string;
  updated: string;
  status: string;
}

interface Props {
  trend: Trend;
}

const { trend } = Astro.props;
---

<article class="card">
  <div class="card-top">
    <span class="badge">{CATEGORIES[trend.category] ?? trend.category}</span>
    {trend.status === 'hot' && <span class="badge">🔥 HOT</span>}
  </div>
  <h2><a href={`/trends/${trend.slug}`}>{trend.title}</a></h2>
  <p>{trend.summary}</p>
  <p class="muted">Trend score: <span class="score">{trend.trendScore}</span> · Updated {trend.updated}</p>
  <a class="btn" href={`/trends/${trend.slug}`}>View picks →</a>
</article>

<style>
  .card-top {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
</style>
