---
import { CATEGORIES, formatDate } from '../lib/site';

interface Trend {
  slug: string;
  title: string;
  category: string;
  summary: string;
  updated: string;
  status: string;
}

interface Props {
  trend: Trend;
}

const { trend } = Astro.props;
---

<article class="card">
  <div class="card-top">
    <span class="badge">{CATEGORIES[trend.category] ?? trend.category}</span>
    {trend.status === 'hot' && <span class="badge">🔥 Trending</span>}
  </div>
  <h2><a href={`/trends/${trend.slug}`}>{trend.title}</a></h2>
  <p>{trend.summary}</p>
  <p class="muted">Updated {formatDate(trend.updated)}</p>
  <a class="btn" href={`/trends/${trend.slug}`}>Read guide →</a>
</article>

<style>
  .card-top {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
</style>
