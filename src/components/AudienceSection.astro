---
import { AUDIENCE } from '../lib/audience';

interface Props {
  showNotFor?: boolean;
  compact?: boolean;
}

const { showNotFor = false, compact = false } = Astro.props;
---

<section class:list={['audience', compact && 'audience-compact']}>
  <header class="audience-header">
    <h2>{AUDIENCE.primaryLabel}</h2>
    <p class="muted audience-mission">{AUDIENCE.mission}</p>
  </header>

  <div class="persona-grid">
    {
      AUDIENCE.personas.map((persona) => (
        <article class="card persona-card">
          <p class="persona-kicker">{persona.subtitle}</p>
          <h3>{persona.title}</h3>
          <p>{persona.scenario}</p>
          {!compact && (
            <>
              <p class="persona-label">Typical searches</p>
              <ul class="search-examples">
                {persona.searches.map((term) => (
                  <li>
                    <code>{term}</code>
                  </li>
                ))}
              </ul>
            </>
          )}
          <p class="persona-label">What you get here</p>
          <ul>
            {persona.weDeliver.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
          <a class="persona-link" href={persona.exploreHref}>
            {persona.exploreLabel} →
          </a>
        </article>
      ))
    }
  </div>

  {
    showNotFor && (
      <div class="not-for">
        <h3>{AUDIENCE.notForLabel}</h3>
        <ul>
          {AUDIENCE.notFor.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    )
  }
</section>

<style>
  .audience {
    margin-top: 3rem;
  }

  .audience-header h2 {
    margin: 0 0 0.5rem;
    font-size: 1.35rem;
  }

  .audience-mission {
    max-width: 42rem;
    margin: 0;
  }

  .persona-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    margin-top: 1.25rem;
  }

  .persona-card h3 {
    margin: 0.15rem 0 0.5rem;
    font-size: 1.05rem;
  }

  .persona-kicker {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--accent-2);
  }

  .persona-label {
    margin: 0.85rem 0 0.35rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--muted);
  }

  .persona-card ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .search-examples {
    list-style: none;
    padding-left: 0;
  }

  .search-examples li {
    margin-bottom: 0.35rem;
  }

  .search-examples code {
    font-size: 0.82rem;
    color: #c7d2fe;
    background: rgba(34, 211, 238, 0.08);
    padding: 0.15rem 0.4rem;
    border-radius: 6px;
  }

  .persona-link {
    display: inline-block;
    margin-top: 0.85rem;
    font-size: 0.92rem;
    font-weight: 600;
  }

  .not-for {
    margin-top: 2rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: rgba(20, 27, 47, 0.65);
  }

  .not-for h3 {
    margin: 0 0 0.5rem;
    font-size: 1rem;
  }

  .not-for ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--muted);
  }

  .audience-compact .persona-grid {
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  }
</style>
