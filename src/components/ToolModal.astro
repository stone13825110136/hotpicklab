---
import tools from '../data/tools.json';
import ToolShell from './ToolShell.astro';
import ToolWidget from './tools/ToolWidget.astro';

interface Props {
  slugs?: string[];
}

const { slugs } = Astro.props;
const modalTools = slugs?.length
  ? tools.filter((t) => slugs.includes(t.slug))
  : tools;
---

<div id="tool-modal-root" class="tool-modal-root" hidden>
  <div class="tool-modal-backdrop" data-close-tool-modal></div>
  <div
    class="tool-modal-panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="tool-modal-title"
  >
    <button type="button" class="tool-modal-close" data-close-tool-modal aria-label="Close tool">
      ×
    </button>
    {
      modalTools.map((tool) => (
        <div class="tool-modal-content" data-tool-panel={tool.slug} hidden>
          <ToolShell title={tool.shortTitle ?? tool.title} compact>
            <ToolWidget slug={tool.slug} />
          </ToolShell>
          <p class="tool-modal-foot">
            <a href={`/tools/${tool.slug}`}>Open standalone tool page →</a>
          </p>
        </div>
      ))
    }
  </div>
</div>

<style>
  .tool-modal-root {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: grid;
    place-items: end center;
    padding: 1rem;
  }

  .tool-modal-root[hidden] {
    display: none;
  }

  @media (min-width: 640px) {
    .tool-modal-root {
      place-items: center;
    }
  }

  .tool-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(4, 8, 18, 0.72);
    backdrop-filter: blur(3px);
  }

  .tool-modal-panel {
    position: relative;
    width: min(100%, 460px);
    max-height: min(88vh, 720px);
    overflow: auto;
    z-index: 1;
    animation: slide-up 0.22s ease-out;
  }

  @keyframes slide-up {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .tool-modal-close {
    position: absolute;
    top: 0.55rem;
    right: 0.55rem;
    z-index: 2;
    width: 2rem;
    height: 2rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(20, 27, 47, 0.95);
    color: var(--text);
    font-size: 1.25rem;
    line-height: 1;
    cursor: pointer;
  }

  .tool-modal-foot {
    margin: 0.75rem 0 0;
    text-align: center;
    font-size: 0.88rem;
  }

  .tool-modal-foot a {
    color: var(--muted);
  }
</style>

<script>
  function initToolModal() {
    const root = document.getElementById('tool-modal-root');
    if (!root || root.dataset.bound === 'true') return;
    root.dataset.bound = 'true';

    const panels = Array.from(root.querySelectorAll<HTMLElement>('[data-tool-panel]'));

    function closeModal() {
      root.hidden = true;
      document.body.style.overflow = '';
      panels.forEach((panel) => {
        panel.hidden = true;
      });
    }

    function openModal(slug: string) {
      const panel = panels.find((p) => p.dataset.toolPanel === slug);
      if (!panel) {
        window.location.href = `/tools/${slug}`;
        return;
      }
      panels.forEach((p) => {
        p.hidden = p !== panel;
      });
      root.hidden = false;
      document.body.style.overflow = 'hidden';
      const focusable = panel.querySelector<HTMLElement>('input, select, button');
      focusable?.focus();
    }

    document.querySelectorAll<HTMLElement>('[data-open-tool]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const slug = btn.dataset.openTool;
        if (slug) openModal(slug);
      });
    });

    root.querySelectorAll('[data-close-tool-modal]').forEach((el) => {
      el.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !root.hidden) closeModal();
    });
  }

  initToolModal();
  document.addEventListener('astro:page-load', initToolModal);
</script>
