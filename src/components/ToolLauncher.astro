---
import tools from '../data/tools.json';

interface Props {
  slug: string;
  label?: string;
}

const { slug, label } = Astro.props;
const tool = tools.find((t) => t.slug === slug);

if (!tool) {
  throw new Error(`Tool launcher not found: ${slug}`);
}

const launcherLabel = label ?? tool.launcherLabel ?? `Open ${tool.shortTitle ?? tool.title}`;
---

<div class="tool-launcher-wrap">
  <button type="button" class="btn tool-open-modal" data-open-tool={slug} aria-haspopup="dialog">
    {launcherLabel}
  </button>
  <a class="tool-full-link" href={`/tools/${slug}`}>Open full tool page →</a>
</div>

<style>
  .tool-launcher-wrap {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
    margin: 1rem 0;
  }

  .tool-open-modal {
    border: 0;
    cursor: pointer;
    font: inherit;
  }

  .tool-full-link {
    color: var(--muted);
    font-size: 0.9rem;
  }
</style>
