---
interface Props {
  title: string;
  description?: string;
  compact?: boolean;
}

const { title, description, compact = false } = Astro.props;
---

<div class:list={['tool-shell', { compact }]}>
  <header class="tool-shell-header">
    <h1 class="tool-shell-title">{title}</h1>
    {description && <p class="tool-shell-desc">{description}</p>}
  </header>
  <div class="tool-shell-body">
    <slot />
  </div>
</div>

<style>
  .tool-shell {
    width: min(100%, 420px);
    margin: 0 auto;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) + 4px);
    padding: 1.35rem 1.25rem 1.5rem;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.25);
  }

  .tool-shell.compact {
    width: 100%;
    box-shadow: none;
    border-radius: var(--radius);
    padding: 1rem 1rem 1.1rem;
  }

  .tool-shell-header {
    margin-bottom: 1rem;
  }

  .tool-shell-title {
    margin: 0;
    font-size: 1.25rem;
    line-height: 1.25;
  }

  .tool-shell.compact .tool-shell-title {
    font-size: 1.05rem;
  }

  .tool-shell-desc {
    margin: 0.45rem 0 0;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.45;
  }

  .tool-shell-body :global(label) {
    display: block;
    margin-bottom: 0.35rem;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .tool-shell-body :global(input),
  .tool-shell-body :global(select) {
    width: 100%;
    padding: 0.65rem 0.7rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: #0d1428;
    color: var(--text);
    font: inherit;
    margin-bottom: 0.75rem;
  }

  .tool-shell-body :global(button.tool-action) {
    width: 100%;
    margin-top: 0.25rem;
    padding: 0.7rem 0.9rem;
    border: 0;
    border-radius: 8px;
    background: var(--accent-2);
    color: #042028;
    font-weight: 700;
    cursor: pointer;
    font: inherit;
  }

  .tool-shell-body :global(.tool-result) {
    margin-top: 1rem;
    padding: 0.75rem 0.85rem;
    border-radius: 8px;
    background: rgba(34, 211, 238, 0.08);
    border: 1px solid rgba(34, 211, 238, 0.2);
    font-weight: 600;
    color: #a7f3d0;
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .tool-shell-body :global(.tool-result.is-empty) {
    display: none;
  }

  .tool-shell-body :global(.tool-copy-row) {
    display: none;
    margin-top: 0.65rem;
  }

  .tool-shell-body :global(.tool-copy-row.is-visible) {
    display: block;
  }

  .tool-shell-body :global(.tool-copy-btn) {
    width: 100%;
    padding: 0.55rem 0.8rem;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text);
    font-weight: 600;
    cursor: pointer;
    font: inherit;
  }
</style>
